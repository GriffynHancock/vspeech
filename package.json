{
  "name": "vectorspeech-chat",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"server,client\" -c \"cyan,magenta\" \"bun run server:dev\" \"bun run client:dev\"",
    "server:dev": "bun --watch server/index.ts",
    "client:dev": "vite --port 5173",
    "build": "vite build",
    "start": "NODE_ENV=production bun server/index.ts",
    "setup": "bun install && mkdir -p output temp"
  },
  "dependencies": {
    "elysia": "^1.2.0",
    "@elysiajs/static": "^1.1.0",
    "@elysiajs/cors": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.469.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.6"
  }
}
